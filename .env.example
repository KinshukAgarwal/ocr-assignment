PASSPORT_OCR_APP_NAME=passport-ocr-api
PASSPORT_OCR_LOG_LEVEL=INFO
PASSPORT_OCR_MAX_UPLOAD_BYTES=10485760
PASSPORT_OCR_MAX_PDF_PAGES=2
PASSPORT_OCR_LOCAL_OCR_TIMEOUT_SECONDS=30
PASSPORT_OCR_GOOGLE_OCR_TIMEOUT_SECONDS=15
PASSPORT_OCR_GOOGLE_MAX_RETRIES=1
PASSPORT_OCR_GOOGLE_FALLBACK_ENABLED=false
PASSPORT_OCR_LOW_CONFIDENCE_THRESHOLD=0.72
